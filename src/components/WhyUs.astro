---
import { Icon } from 'astro-icon/components';

const features = [
  {
    title: 'Truly Open',
    description: "No paid versions hiding behind the free one. No 'premium' upsell after you've set everything up. What you download is the full plugin, period.",
    icon: 'lucide:share-2',
  },
  {
    title: 'Quality Over Quantity',
    description: "We don't churn out dozens of half-baked plugins. We pick a problem, build one plugin that handles it properly, and maintain it. Fewer plugins, done right.",
    icon: 'lucide:rocket',
  },
  {
    title: 'Everyone Can Help',
    description: "First PR? Great. Tenth year writing PHP? Also great. Can't code but want to help? Donations keep this running. Every contribution matters.",
    icon: 'lucide:users',
  },
  {
    title: 'We Actually Respond',
    description: "Open an issue and you'll hear back. Ask a question on Discord and someone will answer. We don't let threads die - if we don't know, we'll say so.",
    icon: 'lucide:message-circle-question',
  },
];
---

<section id="why-us" class="py-20 bg-white dark:bg-gray-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white tracking-tight">Why Open WP Club?</h2>
      <p class="mt-4 text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        Because WordPress deserves plugins that are free and actually good - not free-until-you-need-them.
      </p>
    </div>
    <div class="mt-16 grid grid-cols-1 lg:grid-cols-2 gap-8">
      {features.map((feature) => (
        <div class="bg-gradient-to-br from-blue-50 via-white to-blue-50 dark:from-blue-950/30 dark:via-gray-800 dark:to-blue-950/30 rounded-2xl p-8 shadow-sm hover:shadow-lg transition-shadow duration-200 border border-blue-100 dark:border-blue-900/50">
          <div class="flex items-center space-x-3">
            <div class="flex-shrink-0">
              <Icon name={feature.icon} class="size-6 text-blue-500 dark:text-blue-400" />
            </div>
            <h3 class="text-xl font-semibold text-gray-900 dark:text-white">{feature.title}</h3>
          </div>
          <p class="mt-4 text-gray-600 dark:text-gray-400 leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
