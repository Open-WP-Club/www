---
import { Icon } from 'astro-icon/components';
import Logo from './Logo.astro';
import GitHubIcon from './icons/GitHubIcon.astro';
import DiscordIcon from './icons/DiscordIcon.astro';
import TwitterIcon from './icons/TwitterIcon.astro';
import HeartIcon from './icons/HeartIcon.astro';
import MailIcon from './icons/MailIcon.astro';
import { GITHUB_ORG_URL, DISCORD_URL, SPONSOR_URL, CONTACT_EMAIL, TWITTER_URL } from '../lib/config';
import pluginsData from '../data/plugins.json';

const year = new Date().getFullYear();

// Use the most recent lastPush date from plugins data instead of the build date,
// so "Last updated" reflects when content actually changed, not when the site was built.
const lastUpdated = pluginsData
  .map((p: { lastPush?: string }) => p.lastPush)
  .filter(Boolean)
  .sort()
  .pop();
const buildDate = lastUpdated
  ? new Date(lastUpdated).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<footer class="bg-gray-900 dark:bg-gray-950 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-10">

      <!-- Brand -->
      <div>
        <a href="/" class="inline-flex items-center">
          <Logo />
          <span class="ml-3 text-xl font-bold">Open WP Club</span>
        </a>
        <p class="mt-4 text-sm text-gray-400 leading-relaxed">
          Free, open-source WordPress software - built by the community, for the community. No paywalls, no locked features.
        </p>
      </div>

      <!-- Pages -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-300">Pages</h3>
        <ul class="mt-4 space-y-3">
          <li><a href="/" class="text-sm text-gray-400 hover:text-white transition-colors">Home</a></li>
          <li><a href="/plugins/" class="text-sm text-gray-400 hover:text-white transition-colors">Plugins</a></li>
          <li><a href="/apps/" class="text-sm text-gray-400 hover:text-white transition-colors">Apps</a></li>
          <li><a href="/blog/" class="text-sm text-gray-400 hover:text-white transition-colors">Blog</a></li>
          <li><a href="/contributors/" class="text-sm text-gray-400 hover:text-white transition-colors">Contributors</a></li>
          <li><a href="/mission/" class="text-sm text-gray-400 hover:text-white transition-colors">Our Mission</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-300">Resources</h3>
        <ul class="mt-4 space-y-3">
          <li><a href="/tech-stack/" class="text-sm text-gray-400 hover:text-white transition-colors">Tech Stack</a></li>
          <li><a href="/join/" class="text-sm text-gray-400 hover:text-white transition-colors">How to Join</a></li>
          <li><a href="/faq/" class="text-sm text-gray-400 hover:text-white transition-colors">FAQ</a></li>
          <li><a href="/changelog/" class="text-sm text-gray-400 hover:text-white transition-colors">Changelog</a></li>
          <li><a href="/privacy/" class="text-sm text-gray-400 hover:text-white transition-colors">Privacy Policy</a></li>
        </ul>
      </div>

      <!-- Community -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-300">Community</h3>
        <ul class="mt-4 space-y-3">
          <li>
            <a href={GITHUB_ORG_URL} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors">
              <GitHubIcon class="size-4" />
              GitHub
            </a>
          </li>
          <li>
            <a href={DISCORD_URL} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors">
              <DiscordIcon class="size-4" />
              Discord
            </a>
          </li>
          <li>
            <a href={TWITTER_URL} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors">
              <TwitterIcon class="size-4" />
              Twitter/X
            </a>
          </li>
          <li>
            <a href={`${GITHUB_ORG_URL}/.github/blob/main/CONTRIBUTING.md`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors">
              <Icon name="lucide:git-pull-request" class="size-4" />
              Contribute
            </a>
          </li>
        </ul>
      </div>

      <!-- Support -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-300">Support</h3>
        <ul class="mt-4 space-y-3">
          {SPONSOR_URL && (
            <li>
              <a href={SPONSOR_URL} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors">
                <HeartIcon class="size-4" />
                Sponsor
              </a>
            </li>
          )}
          <li>
            <a href={`mailto:${CONTACT_EMAIL}`} class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors">
              <MailIcon class="size-4" />
              Contact
            </a>
          </li>
          <li>
            <a href={`${GITHUB_ORG_URL}/.github/issues`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors">
              <Icon name="lucide:circle-alert" class="size-4" />
              Report an Issue
            </a>
          </li>
          <li>
            <a href="/llms.txt" class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors">
              <Icon name="lucide:file-text" class="size-4" />
              llms.txt
            </a>
          </li>
          <li>
            <a href="/humans.txt" class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors">
              <Icon name="lucide:user" class="size-4" />
              humans.txt
            </a>
          </li>
          <li>
            <a href="/.well-known/security.txt" class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors">
              <Icon name="lucide:shield-check" class="size-4" />
              security.txt
            </a>
          </li>
        </ul>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-gray-800 dark:border-gray-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="md:flex md:items-center md:justify-between">
        <p class="text-sm text-gray-500">
          &copy; 2024&ndash;{year} Open WP Club. All rights reserved.
        </p>
        <p class="mt-4 md:mt-0 text-xs text-gray-600 max-w-2xl leading-relaxed">
          WordPress&reg; is a registered trademark of the WordPress Foundation.
          This website is not affiliated with or sponsored by Automattic, Inc. or the WordPress Foundation.
          <span class="block mt-1">Last updated: {buildDate}</span>
          <span class="block mt-1">This site does not use cookies or track individual visitors.</span>
        </p>
      </div>
    </div>
  </div>
</footer>
