---
import { Icon } from 'astro-icon/components';

interface Props {
  stars: number;
  lastPush: string;
  downloads?: string;
  language?: string | null;
  license?: string | null;
  compact?: boolean;
}

const { stars, lastPush, downloads, language, license, compact = false } = Astro.props;

const downloadsNum = downloads ? parseInt(downloads, 10) : 0;

function formatDate(dateStr: string): string {
  if (!dateStr) return 'N/A';
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}

function timeAgo(dateStr: string): string {
  if (!dateStr) return 'N/A';
  const now = new Date();
  const date = new Date(dateStr);
  const diffMs = now.getTime() - date.getTime();
  const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
  if (diffDays === 0) return 'today';
  if (diffDays === 1) return 'yesterday';
  if (diffDays < 30) return `${diffDays}d ago`;
  if (diffDays < 365) return `${Math.floor(diffDays / 30)}mo ago`;
  return `${Math.floor(diffDays / 365)}y ago`;
}
---

<div class={`flex flex-wrap gap-3 text-sm text-gray-600 dark:text-gray-400 ${compact ? '' : 'gap-4'}`}>
  <span class="inline-flex items-center gap-1">
    <Icon name="lucide:star" class="size-4" />
    {stars}
  </span>
  {downloadsNum > 0 && (
    <span class="inline-flex items-center gap-1">
      <Icon name="lucide:download" class="size-4" />
      {downloadsNum.toLocaleString()}
    </span>
  )}
  {lastPush && (
    <span class="inline-flex items-center gap-1" title={formatDate(lastPush)}>
      <Icon name="lucide:clock" class="size-4" />
      {compact ? timeAgo(lastPush) : formatDate(lastPush)}
    </span>
  )}
  {!compact && language && (
    <span class="inline-flex items-center gap-1">
      <span class="size-3 rounded-full bg-blue-500"></span>
      {language}
    </span>
  )}
  {!compact && license && (
    <span class="inline-flex items-center gap-1">
      <Icon name="lucide:scale" class="size-4" />
      {license}
    </span>
  )}
</div>
