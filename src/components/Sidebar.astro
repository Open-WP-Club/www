---
import { Icon } from 'astro-icon/components';
import GitHubIcon from './icons/GitHubIcon.astro';
import DiscordIcon from './icons/DiscordIcon.astro';
import HeartIcon from './icons/HeartIcon.astro';
import MailIcon from './icons/MailIcon.astro';
import { GITHUB_ORG_URL, DISCORD_URL, SPONSOR_URL, CONTACT_EMAIL } from '../lib/config';

interface Props {
  showWriteForUs?: boolean;
}
const { showWriteForUs = false } = Astro.props;
---

<div class="space-y-6">
  <!-- Sponsor CTA -->
  <div class="bg-gradient-to-br from-amber-50 via-white to-amber-50 dark:from-amber-950/20 dark:via-gray-800 dark:to-amber-950/20 rounded-xl shadow-sm border border-amber-200 dark:border-amber-800/50 p-6">
    <h3 class="text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-2">Sponsor us</h3>
    <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-4">
      Our software is free forever. Sponsorships help us maintain all our plugins and build new tools for the WordPress ecosystem.
    </p>
    {SPONSOR_URL && (
      <a
        href={SPONSOR_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center w-full gap-2 px-4 py-2.5 text-sm font-medium text-white bg-amber-500 hover:bg-amber-600 rounded-lg transition-colors mb-2"
      >
        <HeartIcon class="size-4" />
        Become a Sponsor
      </a>
    )}
    <a
      href={`mailto:${CONTACT_EMAIL}?subject=Sponsorship Inquiry`}
      class={`inline-flex items-center justify-center w-full gap-2 px-4 py-2.5 text-sm font-medium rounded-lg transition-colors ${SPONSOR_URL ? 'text-amber-700 dark:text-amber-300 bg-amber-50 dark:bg-amber-900/20 hover:bg-amber-100 dark:hover:bg-amber-900/40 border border-amber-200 dark:border-amber-800/50' : 'text-white bg-amber-500 hover:bg-amber-600'}`}
    >
      <MailIcon class="size-4" />
      Contact us about sponsoring
    </a>
  </div>

  <!-- Community -->
  <div class="bg-gradient-to-br from-blue-50 via-white to-blue-50 dark:from-blue-950/20 dark:via-gray-800 dark:to-blue-950/20 rounded-xl shadow-sm border border-blue-100 dark:border-blue-900/50 p-6">
    <h3 class="text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-3">Community</h3>
    <div class="space-y-3">
      <a
        href={GITHUB_ORG_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-3 text-sm text-gray-700 dark:text-gray-300 hover:text-blue-500 dark:hover:text-blue-400 transition-colors"
      >
        <GitHubIcon class="size-5 shrink-0" />
        View on GitHub
      </a>
      <a
        href={DISCORD_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-3 text-sm text-gray-700 dark:text-gray-300 hover:text-blue-500 dark:hover:text-blue-400 transition-colors"
      >
        <DiscordIcon class="size-5 shrink-0" />
        Join Discord
      </a>
      <a
        href={`mailto:${CONTACT_EMAIL}`}
        class="flex items-center gap-3 text-sm text-gray-700 dark:text-gray-300 hover:text-blue-500 dark:hover:text-blue-400 transition-colors"
      >
        <MailIcon class="size-5 shrink-0" />
        {CONTACT_EMAIL}
      </a>
    </div>
  </div>

  {showWriteForUs && (
    <!-- Write for us -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
      <h3 class="text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-2">Write for us</h3>
      <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-4">
        Got a WordPress story, tutorial, or opinion? We welcome guest posts from the community.
      </p>
      <a
        href={`mailto:${CONTACT_EMAIL}?subject=Guest Post Proposal`}
        class="inline-flex items-center justify-center w-full gap-2 px-4 py-2 text-sm font-medium text-blue-500 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/20 hover:bg-blue-100 dark:hover:bg-blue-900/40 border border-blue-200 dark:border-blue-800/50 rounded-lg transition-colors"
      >
        <Icon name="lucide:pen-line" class="size-4" />
        Pitch a guest post
      </a>
    </div>
  )}

  <!-- Quick Links -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
    <h3 class="text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-3">Explore</h3>
    <div class="space-y-3">
      <a href="/plugins/" class="flex items-center gap-3 text-sm text-gray-700 dark:text-gray-300 hover:text-blue-500 dark:hover:text-blue-400 transition-colors">
        <Icon name="lucide:puzzle" class="size-5 shrink-0" />
        All Plugins
      </a>
      <a href="/apps/" class="flex items-center gap-3 text-sm text-gray-700 dark:text-gray-300 hover:text-blue-500 dark:hover:text-blue-400 transition-colors">
        <Icon name="lucide:monitor" class="size-5 shrink-0" />
        Apps
      </a>
      <a href="/mission/" class="flex items-center gap-3 text-sm text-gray-700 dark:text-gray-300 hover:text-blue-500 dark:hover:text-blue-400 transition-colors">
        <Icon name="lucide:landmark" class="size-5 shrink-0" />
        Our Mission
      </a>
    </div>
  </div>
</div>
