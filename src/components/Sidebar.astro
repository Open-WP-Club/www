---
import GitHubIcon from './icons/GitHubIcon.astro';
import DiscordIcon from './icons/DiscordIcon.astro';
import HeartIcon from './icons/HeartIcon.astro';
import MailIcon from './icons/MailIcon.astro';
import { GITHUB_ORG_URL, DISCORD_URL, SPONSOR_URL, CONTACT_EMAIL } from '../lib/config';

interface Props {
  showWriteForUs?: boolean;
}
const { showWriteForUs = false } = Astro.props;
---

<div class="space-y-6">
  <!-- Sponsor CTA -->
  <div class="bg-gradient-to-br from-amber-50 via-white to-amber-50 dark:from-amber-950/20 dark:via-gray-800 dark:to-amber-950/20 rounded-xl shadow-sm border border-amber-200 dark:border-amber-800/50 p-6">
    <h3 class="text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-2">Sponsor us</h3>
    <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-4">
      Our software is free forever. Sponsorships help us maintain all our plugins and build new tools for the WordPress ecosystem.
    </p>
    {SPONSOR_URL && (
      <a
        href={SPONSOR_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center w-full gap-2 px-4 py-2.5 text-sm font-medium text-white bg-amber-500 hover:bg-amber-600 rounded-lg transition-colors mb-2"
      >
        <HeartIcon class="size-4" />
        Become a Sponsor
      </a>
    )}
    <a
      href={`mailto:${CONTACT_EMAIL}?subject=Sponsorship Inquiry`}
      class={`inline-flex items-center justify-center w-full gap-2 px-4 py-2.5 text-sm font-medium rounded-lg transition-colors ${SPONSOR_URL ? 'text-amber-700 dark:text-amber-300 bg-amber-50 dark:bg-amber-900/20 hover:bg-amber-100 dark:hover:bg-amber-900/40 border border-amber-200 dark:border-amber-800/50' : 'text-white bg-amber-500 hover:bg-amber-600'}`}
    >
      <MailIcon class="size-4" />
      Contact us about sponsoring
    </a>
  </div>

  <!-- Community -->
  <div class="bg-gradient-to-br from-blue-50 via-white to-blue-50 dark:from-blue-950/20 dark:via-gray-800 dark:to-blue-950/20 rounded-xl shadow-sm border border-blue-100 dark:border-blue-900/50 p-6">
    <h3 class="text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-3">Community</h3>
    <div class="space-y-3">
      <a
        href={GITHUB_ORG_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-3 text-sm text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
      >
        <GitHubIcon class="size-5 shrink-0" />
        View on GitHub
      </a>
      <a
        href={DISCORD_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-3 text-sm text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
      >
        <DiscordIcon class="size-5 shrink-0" />
        Join Discord
      </a>
      <a
        href={`mailto:${CONTACT_EMAIL}`}
        class="flex items-center gap-3 text-sm text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
      >
        <MailIcon class="size-5 shrink-0" />
        {CONTACT_EMAIL}
      </a>
    </div>
  </div>

  {showWriteForUs && (
    <!-- Write for us -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
      <h3 class="text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-2">Write for us</h3>
      <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-4">
        Got a WordPress story, tutorial, or opinion? We welcome guest posts from the community.
      </p>
      <a
        href={`mailto:${CONTACT_EMAIL}?subject=Guest Post Proposal`}
        class="inline-flex items-center justify-center w-full gap-2 px-4 py-2 text-sm font-medium text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/20 hover:bg-blue-100 dark:hover:bg-blue-900/40 border border-blue-200 dark:border-blue-800/50 rounded-lg transition-colors"
      >
        <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
        </svg>
        Pitch a guest post
      </a>
    </div>
  )}

  <!-- Quick Links -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
    <h3 class="text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-3">Explore</h3>
    <div class="space-y-3">
      <a href="/plugins/" class="flex items-center gap-3 text-sm text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
        <svg class="size-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 01-.657.643 48.39 48.39 0 01-4.163-.3c.186 1.613.293 3.25.315 4.907a.656.656 0 01-.658.663v0c-.355 0-.676-.186-.959-.401a1.647 1.647 0 00-1.003-.349c-1.036 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401v0c.31 0 .555.26.532.57a48.039 48.039 0 01-.642 5.056c1.518.19 3.058.309 4.616.354a.64.64 0 00.657-.643v0c0-.355-.186-.676-.401-.959a1.647 1.647 0 01-.349-1.003c0-1.035 1.008-1.875 2.25-1.875 1.243 0 2.25.84 2.25 1.875 0 .369-.128.713-.349 1.003-.215.283-.4.604-.4.959v0c0 .333.277.599.61.58a48.1 48.1 0 005.427-.63 48.05 48.05 0 00.582-4.717.532.532 0 00-.533-.57v0c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.035 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.37 0 .713.128 1.003.349.283.215.604.401.96.401v0a.656.656 0 00.658-.663 48.422 48.422 0 00-.37-5.36c-1.886.342-3.81.574-5.766.689a.578.578 0 01-.61-.58v0z" />
        </svg>
        All Plugins
      </a>
      <a href="/apps/" class="flex items-center gap-3 text-sm text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
        <svg class="size-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25A2.25 2.25 0 015.25 3h13.5A2.25 2.25 0 0121 5.25z" />
        </svg>
        Apps
      </a>
      <a href="/mission/" class="flex items-center gap-3 text-sm text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
        <svg class="size-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21" />
        </svg>
        Our Mission
      </a>
    </div>
  </div>
</div>
