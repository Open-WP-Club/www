---
import HeartIcon from './icons/HeartIcon.astro';
import MailIcon from './icons/MailIcon.astro';
import { SPONSOR_URL, CONTACT_EMAIL } from '../lib/config';
---

<section class="py-20 bg-gradient-to-br from-amber-50 via-white to-amber-50 dark:from-amber-950/20 dark:via-gray-900 dark:to-amber-950/20">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white tracking-tight">Support free WordPress software</h2>
    <p class="mt-6 text-lg text-gray-600 dark:text-gray-400 leading-relaxed max-w-2xl mx-auto">
      We maintain dozens of plugins and build new tools - all free, all open source. Sponsorships help us keep doing this full-time instead of side-project pace.
    </p>
    <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center items-center">
      {SPONSOR_URL && (
        <a
          href={SPONSOR_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center px-8 py-4 text-base font-medium rounded-lg text-white bg-amber-500 hover:bg-amber-600 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition-all duration-200"
        >
          <HeartIcon class="size-5 mr-3" />
          Become a Sponsor
        </a>
      )}
      <a
        href={`mailto:${CONTACT_EMAIL}?subject=Sponsorship Inquiry`}
        class={`inline-flex items-center px-8 py-4 text-base font-medium rounded-lg shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition-all duration-200 ${SPONSOR_URL ? 'text-amber-700 dark:text-amber-300 bg-white dark:bg-gray-800 border border-amber-200 dark:border-amber-700 hover:bg-amber-50 dark:hover:bg-gray-700' : 'text-white bg-amber-500 hover:bg-amber-600'}`}
      >
        <MailIcon class="size-5 mr-3" />
        Get in touch
      </a>
    </div>
    <p class="mt-6 text-sm text-gray-500 dark:text-gray-500">
      Every sponsor directly funds plugin maintenance, bug fixes, and new features for the WordPress community.
    </p>
  </div>
</section>
