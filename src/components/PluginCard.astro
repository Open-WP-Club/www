---
import { Icon } from 'astro-icon/components';
import PluginStats from './PluginStats.astro';

interface Props {
  slug: string;
  name: string;
  description: string;
  version: string;
  stars: number;
  forks: number;
  lastPush: string;
  downloads?: string;
  language?: string | null;
}

const { slug, name, description, version, stars, forks, lastPush, downloads, language } = Astro.props;

const languageColors: Record<string, string> = {
  PHP: '#4F5D95',
  TypeScript: '#3178C6',
  JavaScript: '#F1E05A',
  Python: '#3572A5',
  CSS: '#563D7C',
  HTML: '#E34C26',
  Shell: '#89E051',
  Astro: '#FF5D01',
};

const langColor = language ? (languageColors[language] || '#6B7280') : '#6B7280';
---

<a href={`/plugins/${slug}/`} class="block plugin-card bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm hover:shadow-lg border border-gray-200 dark:border-gray-700 hover:border-blue-200 dark:hover:border-blue-700 transition-all duration-200">
  <div class="flex items-center space-x-2 mb-3">
    <div class="flex-shrink-0">
      <Icon name="lucide:code" class="size-5 text-blue-500 dark:text-blue-400" />
    </div>
    <h3 class="text-lg font-semibold text-gray-900 dark:text-white truncate">{name}</h3>
  </div>

  <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed mb-4 line-clamp-3">{description}</p>

  <div class="flex flex-wrap gap-1.5 mb-4">
    {version && version !== 'N/A' && (
      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 dark:bg-blue-900/40 text-blue-800 dark:text-blue-300">
        v{version}
      </span>
    )}
    {language && (
      <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300">
        <span class="size-2 rounded-full shrink-0" style={`background-color: ${langColor}`}></span>
        {language}
      </span>
    )}
  </div>

  <PluginStats stars={stars} forks={forks} lastPush={lastPush} downloads={downloads} compact />
</a>
