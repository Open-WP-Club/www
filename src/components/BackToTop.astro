---
import { Icon } from 'astro-icon/components';
/**
 * Back to Top button. Appears after scrolling down 400px.
 */
---

<button
  id="back-to-top"
  class="fixed bottom-6 right-6 z-40 hidden size-10 items-center justify-center rounded-full bg-blue-500 text-white shadow-lg hover:bg-blue-600 transition-all duration-200 hover:scale-110"
  aria-label="Back to top"
>
  <Icon name="lucide:chevron-up" class="size-5" />
</button>

<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('back-to-top');
    if (!btn) return;

    let ticking = false;
    const toggle = () => {
      if (window.scrollY > 400) {
        btn.classList.remove('hidden');
        btn.classList.add('flex');
      } else {
        btn.classList.add('hidden');
        btn.classList.remove('flex');
      }
      ticking = false;
    };

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(toggle);
        ticking = true;
      }
    }, { passive: true });
    toggle();

    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });
</script>
