---
import { ClientRouter } from 'astro:transitions';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
import '../styles/global.css';
import { GITHUB_ORG_URL, DISCORD_URL, TWITTER_HANDLE, TWITTER_URL } from '../lib/config';

interface Props {
  title: string;
  description?: string;
  ogType?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown>;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
  title,
  description = 'Open WP Club builds free, open-source WordPress plugins. Browse our catalog, read the source, and use them in your projects.',
  ogType = 'website',
  ogImage = new URL('/og-image.svg', Astro.site).toString(),
  jsonLd,
} = Astro.props;

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Open WP Club',
  url: 'https://openwpclub.com',
  logo: 'https://openwpclub.com/favicon.svg',
  sameAs: [GITHUB_ORG_URL, DISCORD_URL],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Dark mode: prevent flash of wrong theme -->
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('theme');
        if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.svg" />

    <!-- Resource hints -->
    <link rel="preconnect" href="https://github.com" />
    <link rel="dns-prefetch" href="https://github.com" />
    <link rel="preconnect" href="https://raw.githubusercontent.com" />
    <link rel="dns-prefetch" href="https://raw.githubusercontent.com" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Open WP Club" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="Open WP Club Blog" href="/rss.xml" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Open WP Club" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    {TWITTER_HANDLE && <meta name="twitter:site" content={TWITTER_HANDLE} />}
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Robots -->
    <meta name="robots" content="index, follow" />

    <!-- Social verification -->
    <link rel="me" href={GITHUB_ORG_URL} />
    <link rel="me" href={DISCORD_URL} />
    <link rel="me" href={TWITTER_URL} />

    <!-- View Transitions -->
    <ClientRouter />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <!-- Analytics: Replace YOUR_TOKEN with your Cloudflare Web Analytics token -->
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "YOUR_TOKEN"}'></script>
  </head>
  <body class="font-sans antialiased bg-gray-50 text-gray-900 dark:bg-gray-950 dark:text-gray-100">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:p-4 focus:bg-white dark:focus:bg-gray-900 focus:text-blue-600 focus:underline">
      Skip to content
    </a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <BackToTop />
  </body>
</html>
