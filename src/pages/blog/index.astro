---
import { Icon } from 'astro-icon/components';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout
  title="Blog - Open WP Club"
  description="Updates, guides, and thoughts on building free WordPress software."
>
  <Breadcrumbs items={[{ label: 'Blog' }]} />

  <!-- Hero -->
  <section class="pt-8 pb-20 bg-gradient-to-br from-blue-50 to-white dark:from-gray-900 dark:to-gray-950">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 dark:text-white leading-tight tracking-tight">Blog</h1>
        <p class="mt-6 text-lg sm:text-xl text-gray-600 dark:text-gray-400 leading-relaxed max-w-2xl mx-auto">
          Updates, releases, and thoughts on building free WordPress software.
        </p>
      </div>
    </div>
  </section>

  <!-- Two-column: Content + Sidebar -->
  <section class="py-12 bg-gray-50 dark:bg-gray-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-3 lg:gap-8 lg:items-start">

        <!-- Main content -->
        <div class="lg:col-span-2 space-y-6">
          {posts.length === 0 && (
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-8 text-center">
              <p class="text-gray-500 dark:text-gray-500">No posts yet. Check back soon.</p>
            </div>
          )}
          {posts.map((post) => (
            <a
              href={`/blog/${post.id}/`}
              class="blog-item block bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 hover:shadow-lg hover:border-blue-200 dark:hover:border-blue-700 transition-all duration-200"
              data-title={post.data.title.toLowerCase()}
              data-description={post.data.description.toLowerCase()}
              data-tags={post.data.tags.join(' ').toLowerCase()}
            >
              <div class="flex items-center gap-3 flex-wrap">
                <time class="text-xs font-medium text-blue-500 uppercase tracking-wider">
                  {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <span class="inline-flex items-center gap-1 text-xs text-gray-400 dark:text-gray-500">
                  <Icon name="lucide:clock" class="size-3" />
                  {Math.max(1, Math.round((post.body?.split(/\s+/).length || 0) / 200))} min
                </span>
                {post.data.tags.map((tag) => (
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300">
                    #{tag}
                  </span>
                ))}
              </div>
              <h2 class="mt-2 text-xl font-bold text-gray-900 dark:text-white">{post.data.title}</h2>
              <p class="mt-2 text-gray-600 dark:text-gray-400 leading-relaxed">{post.data.description}</p>
              <p class="mt-3 text-sm text-gray-400 dark:text-gray-500">By {post.data.author}</p>
            </a>
          ))}
          <p id="no-blog-results" class="hidden text-center text-gray-500 dark:text-gray-500 py-8">No posts match your search.</p>
        </div>

        <!-- Sidebar -->
        <div class="mt-8 lg:mt-0">
          <div class="lg:sticky lg:top-24">
            <div class="mb-6 rounded-2xl border border-blue-100 dark:border-blue-900/50 bg-gradient-to-br from-white via-blue-50/70 to-slate-50 dark:from-gray-800 dark:via-gray-800 dark:to-gray-900 shadow-sm p-6">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h2 class="text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-wider">Browse posts</h2>
                  <p class="mt-2 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
                    Filter by topic, search the archive, or subscribe via RSS.
                  </p>
                </div>
                <a href="/rss.xml" class="inline-flex items-center gap-1.5 rounded-full px-3 py-1.5 text-xs font-medium bg-orange-100 dark:bg-orange-900/30 text-orange-700 dark:text-orange-300 hover:bg-orange-200 dark:hover:bg-orange-900/50 transition-colors shrink-0" target="_blank" rel="noopener noreferrer">
                  <Icon name="lucide:rss" class="size-3.5" />
                  RSS
                </a>
              </div>

              <div class="mt-5 relative">
                <Icon name="lucide:search" class="absolute left-3 top-1/2 -translate-y-1/2 size-4.5 text-gray-400 pointer-events-none" />
                <input
                  id="blog-search"
                  type="search"
                  placeholder="Search posts..."
                  class="w-full pl-10 pr-4 py-3 rounded-xl border border-blue-100 dark:border-gray-700 bg-white/90 dark:bg-gray-900 text-sm text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
                  aria-label="Search blog posts"
                />
              </div>

              {allTags.length > 0 && (
                <div class="mt-5">
                  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-gray-500 dark:text-gray-400">Topics</p>
                  <div class="mt-3 flex flex-wrap gap-2" id="tag-filters">
                    <button data-tag="all" class="tag-btn inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium bg-blue-500 text-white transition-colors">
                      All
                    </button>
                    {allTags.map((tag) => (
                      <button
                        data-tag={tag}
                        class="tag-btn inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium bg-blue-100 dark:bg-blue-900/40 text-blue-800 dark:text-blue-300 hover:bg-blue-200 dark:hover:bg-blue-900/60 transition-colors"
                      >
                        #{tag}
                      </button>
                    ))}
                  </div>
                </div>
              )}
            </div>
            <Sidebar showWriteForUs={true} />
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { debounce } from '../../lib/debounce';

  document.addEventListener('astro:page-load', () => {
    const search = document.getElementById('blog-search') as HTMLInputElement | null;
    const noResults = document.getElementById('no-blog-results');
    const tagBtns = document.querySelectorAll('.tag-btn') as NodeListOf<HTMLButtonElement>;
    if (!search || !noResults) return;

    const items = [...document.querySelectorAll('.blog-item')] as HTMLElement[];
    let activeTag = 'all';

    function updateTagButtons() {
      tagBtns.forEach((btn) => {
        const tag = btn.dataset.tag;
        const isActive = tag === activeTag;
        if (isActive) {
          btn.className = 'tag-btn inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-500 text-white transition-colors';
        } else {
          btn.className = 'tag-btn inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 dark:bg-blue-900/40 text-blue-800 dark:text-blue-300 hover:bg-blue-200 dark:hover:bg-blue-900/60 transition-colors';
        }
      });
    }

    function update() {
      const query = search!.value.toLowerCase().trim();
      let visibleCount = 0;
      items.forEach((item) => {
        const title = item.dataset.title || '';
        const desc = item.dataset.description || '';
        const tags = item.dataset.tags || '';
        const matchSearch = !query || title.includes(query) || desc.includes(query) || tags.includes(query);
        const matchTag = activeTag === 'all' || tags.includes(activeTag);
        const show = matchSearch && matchTag;
        item.style.display = show ? '' : 'none';
        if (show) visibleCount++;
      });
      noResults!.classList.toggle('hidden', visibleCount > 0);
    }

    tagBtns.forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        activeTag = btn.dataset.tag || 'all';
        updateTagButtons();
        update();
      });
    });

    search.addEventListener('input', debounce(update, 150));

    update();
  });
</script>
