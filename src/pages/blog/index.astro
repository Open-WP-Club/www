---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout
  title="Blog - Open WP Club"
  description="Updates, guides, and thoughts on building free WordPress software."
>
  <Breadcrumbs items={[{ label: 'Blog' }]} />

  <!-- Hero -->
  <section class="pt-8 pb-20 bg-gradient-to-br from-blue-50 to-white dark:from-gray-900 dark:to-gray-950">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 dark:text-white leading-tight tracking-tight">Blog</h1>
        <p class="mt-6 text-lg sm:text-xl text-gray-600 dark:text-gray-400 leading-relaxed max-w-2xl mx-auto">
          Updates, releases, and thoughts on building free WordPress software.
        </p>
        <a href="/rss.xml" class="inline-flex items-center gap-1.5 mt-4 px-3 py-1 rounded-full text-sm font-medium bg-orange-100 dark:bg-orange-900/30 text-orange-700 dark:text-orange-300 hover:bg-orange-200 dark:hover:bg-orange-900/50 transition-colors" target="_blank" rel="noopener noreferrer">
          <svg class="size-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M6.503 20.752c0 1.794-1.456 3.248-3.251 3.248-1.796 0-3.252-1.454-3.252-3.248 0-1.794 1.456-3.248 3.252-3.248 1.795.001 3.251 1.454 3.251 3.248zm-6.503-12.572v4.811c6.05.062 10.96 4.966 11.022 11.009h4.817c-.062-8.742-7.115-15.783-15.839-15.82zm0-8.18v4.819c12.432.058 22.505 10.118 22.565 22.508h4.81c-.061-15.092-12.345-27.347-27.375-27.327z"/>
          </svg>
          RSS Feed
        </a>
        {allTags.length > 0 && (
          <div class="mt-6 flex flex-wrap justify-center gap-2">
            {allTags.map((tag) => (
              <a
                href={`/blog/tag/${tag}/`}
                class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 dark:bg-blue-900/40 text-blue-800 dark:text-blue-300 hover:bg-blue-200 dark:hover:bg-blue-900/60 transition-colors"
              >
                #{tag}
              </a>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Two-column: Content + Sidebar -->
  <section class="py-12 bg-gray-50 dark:bg-gray-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-3 lg:gap-8">

        <!-- Main content -->
        <div class="lg:col-span-2 space-y-6">
          {posts.length === 0 && (
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-8 text-center">
              <p class="text-gray-500 dark:text-gray-500">No posts yet. Check back soon.</p>
            </div>
          )}
          {posts.map((post) => (
            <a
              href={`/blog/${post.id}/`}
              class="block bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 hover:shadow-lg hover:border-blue-200 dark:hover:border-blue-700 transition-all duration-200"
            >
              <div class="flex items-center gap-3 flex-wrap">
                <time class="text-xs font-medium text-blue-500 uppercase tracking-wider">
                  {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                {post.data.tags.map((tag) => (
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300">
                    #{tag}
                  </span>
                ))}
              </div>
              <h2 class="mt-2 text-xl font-bold text-gray-900 dark:text-white">{post.data.title}</h2>
              <p class="mt-2 text-gray-600 dark:text-gray-400 leading-relaxed">{post.data.description}</p>
              <p class="mt-3 text-sm text-gray-400 dark:text-gray-500">By {post.data.author}</p>
            </a>
          ))}
        </div>

        <!-- Sidebar -->
        <div class="mt-8 lg:mt-0">
          <div class="lg:sticky lg:top-24">
            <Sidebar showWriteForUs={true} />
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
