---
import { Icon } from 'astro-icon/components';
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import Contact from '../components/Contact.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';
import { GITHUB_ORG_URL, DISCORD_URL, CONTACT_EMAIL } from '../lib/config';

const allItems = await getCollection('plugins');
const pluginCount = allItems.filter((p) => p.data.category === 'plugin').length;

const ways = [
  {
    icon: 'lucide:code',
    title: 'Write code',
    description: 'Pick an open issue, fix a bug, or build a new feature. We use PHP for plugins, Astro + Tailwind for the website, and TypeScript for tooling.',
    action: 'Browse open issues',
    href: `${GITHUB_ORG_URL}/.github/issues`,
  },
  {
    icon: 'lucide:bug',
    title: 'Test & report bugs',
    description: 'Install our plugins, use them on real sites, and tell us what breaks. Detailed bug reports are just as valuable as code.',
    action: 'Report a bug',
    href: `${GITHUB_ORG_URL}/.github/issues/new`,
  },
  {
    icon: 'lucide:file-text',
    title: 'Write documentation',
    description: 'Improve README files, write tutorials, or translate existing docs. Good documentation makes plugins usable.',
    action: 'See contributing guide',
    href: `${GITHUB_ORG_URL}/.github/blob/main/CONTRIBUTING.md`,
  },
  {
    icon: 'lucide:message-circle',
    title: 'Help in the community',
    description: 'Answer questions on Discord, help newcomers with their first PR, or share our plugins with people who need them.',
    action: 'Join Discord',
    href: DISCORD_URL,
  },
  {
    icon: 'lucide:pen-line',
    title: 'Write for the blog',
    description: 'Got a WordPress story, tutorial, or opinion? We publish guest posts from the community — no editorial gatekeeping.',
    action: 'Pitch a post',
    href: `mailto:${CONTACT_EMAIL}?subject=Guest Post Proposal`,
  },
  {
    icon: 'lucide:heart',
    title: 'Sponsor',
    description: `We run entirely on contributions. Even small sponsorships help us maintain ${pluginCount}+ plugins and keep everything free for everyone.`,
    action: 'Contact about sponsoring',
    href: `mailto:${CONTACT_EMAIL}?subject=Sponsorship Inquiry`,
  },
];

const steps = [
  { step: '1', title: 'Join our Discord', description: 'Say hello, introduce yourself, and ask any questions. No formalities.' },
  { step: '2', title: 'Find something to work on', description: 'Browse our GitHub issues labeled "good first issue" or pick any open bug/feature that interests you.' },
  { step: '3', title: 'Fork, code, PR', description: 'Fork the repo, make your changes, and open a pull request. We review all PRs and help you get them merged.' },
  { step: '4', title: 'You\'re in', description: 'After your first merged contribution, you\'re a contributor. No applications, no approval process, no waiting list.' },
];
---

<BaseLayout
  title="How to Join - Open WP Club"
  description="Join Open WP Club — contribute code, report bugs, write docs, or help the community. No applications, no gatekeeping. Your first PR makes you a member."
>
  <Breadcrumbs items={[{ label: 'How to Join' }]} />

  <!-- Hero -->
  <section class="pt-8 pb-16 bg-gradient-to-br from-blue-50 to-white dark:from-gray-900 dark:to-gray-950">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 dark:text-white leading-tight tracking-tight">
          How to <span class="text-blue-500">join</span>
        </h1>
        <p class="mt-6 text-lg sm:text-xl text-gray-600 dark:text-gray-400 leading-relaxed max-w-3xl mx-auto">
          There's no application form. No interview. No approval committee. You join by contributing — code, docs, bug reports, community help, or anything else that makes our software better.
        </p>
      </div>
    </div>
  </section>

  <!-- Two-column: Content + Sidebar -->
  <section class="py-12 bg-gray-50 dark:bg-gray-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-3 lg:gap-8">

        <!-- Main content -->
        <div class="lg:col-span-2 space-y-10">

          <!-- Ways to contribute -->
          <div>
            <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white tracking-tight mb-2">Ways to contribute</h2>
            <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-8">Pick whatever fits your skills and interests. Every contribution counts equally.</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {ways.map((way) => (
                <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 flex flex-col">
                  <div class="flex items-center gap-3 mb-3">
                    <Icon name={way.icon} class="size-5 text-blue-500 shrink-0" />
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{way.title}</h3>
                  </div>
                  <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed flex-1">{way.description}</p>
                  <a
                    href={way.href}
                    target={way.href.startsWith('http') || way.href.startsWith('mailto') ? '_blank' : undefined}
                    rel={way.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                    class="mt-4 inline-flex items-center text-sm font-medium text-blue-500 hover:text-blue-600 transition-colors"
                  >
                    {way.action}
                    <Icon name="lucide:arrow-right" class="ml-1 size-4" />
                  </a>
                </div>
              ))}
            </div>
          </div>

          <!-- Getting started steps -->
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 sm:p-8">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white tracking-tight mb-6">Getting started</h2>
            <div class="space-y-6">
              {steps.map((item) => (
                <div class="flex gap-4">
                  <div class="flex-shrink-0 flex items-center justify-center size-10 rounded-full bg-blue-100 dark:bg-blue-900/40 text-blue-500 dark:text-blue-400 font-bold text-lg">
                    {item.step}
                  </div>
                  <div>
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{item.title}</h3>
                    <p class="mt-1 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{item.description}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- No gatekeeping -->
          <div class="bg-gradient-to-br from-green-50 via-white to-green-50 dark:from-green-950/30 dark:via-gray-800 dark:to-green-950/30 rounded-xl shadow-sm border border-green-200 dark:border-green-800/50 p-6 sm:p-8">
            <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">No gatekeeping, ever</h2>
            <div class="space-y-4 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
              <p>
                We don't care about your experience level, your resume, or how many GitHub stars you have. If you want to help build free WordPress software, you're welcome here.
              </p>
              <p>
                First-time open source contributor? Great — we'll help you through your first PR. Seasoned maintainer? Even better — we could use your expertise. The only requirement is that you treat everyone with respect.
              </p>
            </div>
          </div>

          <!-- Quick links -->
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <a
              href={DISCORD_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 px-6 py-4 text-base font-medium rounded-lg text-white bg-blue-500 hover:bg-blue-600 shadow-sm transition-all duration-200"
            >
              Join Discord
            </a>
            <a
              href={GITHUB_ORG_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 px-6 py-4 text-base font-medium rounded-lg text-blue-500 dark:text-blue-400 bg-white dark:bg-gray-900 border border-blue-500 hover:bg-blue-50 dark:hover:bg-gray-700 shadow-sm transition-all duration-200"
            >
              View GitHub
            </a>
            <a
              href={`${GITHUB_ORG_URL}/.github/blob/main/CONTRIBUTING.md`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 px-6 py-4 text-base font-medium rounded-lg text-blue-500 dark:text-blue-400 bg-white dark:bg-gray-900 border border-blue-500 hover:bg-blue-50 dark:hover:bg-gray-700 shadow-sm transition-all duration-200"
            >
              Contributing guide
            </a>
          </div>

        </div>

        <!-- Sidebar -->
        <div class="mt-8 lg:mt-0">
          <div class="lg:sticky lg:top-24">
            <Sidebar />
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <Contact />
</BaseLayout>
