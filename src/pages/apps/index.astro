---
import { Icon } from 'astro-icon/components';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

const allItems = await getCollection('plugins');
const apps = allItems.filter((p) => p.data.category === 'app');

const hardcodedApps = [
  {
    name: 'Desktop for WooCommerce',
    description: 'Manage orders, inventory, and customers from a native desktop app - no browser tabs required. Still in development.',
    platform: 'Desktop',
    platformIcon: 'desktop',
    status: 'Coming Soon',
    tags: ['WooCommerce', 'Desktop', 'Orders', 'Inventory'],
  },
  {
    name: 'Android app for WooCommerce',
    description: 'Check orders and update stock from your phone. Push notifications for new orders and low-stock alerts. Early stage - not yet available.',
    platform: 'Android',
    platformIcon: 'mobile',
    status: 'Coming Soon',
    tags: ['WooCommerce', 'Android', 'Mobile', 'Orders'],
  },
];
---

<BaseLayout title="Apps - Open WP Club" description="Desktop and mobile apps for WooCommerce store management. Currently in development by Open WP Club.">
  <Breadcrumbs items={[{ label: 'Apps' }]} />

  <section class="pt-8 pb-16 bg-gradient-to-br from-blue-50 to-white dark:from-gray-900 dark:to-gray-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white tracking-tight">
          Apps
        </h1>
        <p class="mt-4 text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
          Native apps for WooCommerce store management. {apps.length > 0 ? `${apps.length} app${apps.length > 1 ? 's' : ''} available.` : 'These are in active development - none are publicly available yet.'}
        </p>
      </div>
    </div>
  </section>

  <section class="py-12 bg-gray-50 dark:bg-gray-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-3 lg:gap-8">

        <!-- App cards -->
        <div class="lg:col-span-2 space-y-6">

          {/* Real apps from GitHub data */}
          {apps.map((app) => (
            <a href={`/plugins/${app.id}/`} class="block bg-white dark:bg-gray-800 rounded-xl p-8 shadow-sm border border-gray-200 dark:border-gray-700 hover:shadow-lg hover:border-blue-200 dark:hover:border-blue-700 transition-all duration-200">
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
                <div class="flex items-start gap-4">
                  <div class="flex-shrink-0 size-14 flex items-center justify-center rounded-xl bg-blue-100 dark:bg-blue-900/40">
                    <Icon name="lucide:monitor" class="size-7 text-blue-500" />
                  </div>
                  <div>
                    <h2 class="text-xl font-semibold text-gray-900 dark:text-white">{app.data.name}</h2>
                    {app.data.language && (
                      <span class="inline-flex items-center mt-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300">
                        {app.data.language}
                      </span>
                    )}
                  </div>
                </div>
                {app.data.stars > 0 && (
                  <span class="inline-flex items-center gap-1 text-sm text-gray-500">
                    <Icon name="lucide:star" class="size-4" />
                    {app.data.stars}
                  </span>
                )}
              </div>
              <p class="mt-4 text-gray-600 dark:text-gray-400 leading-relaxed">{app.data.description}</p>
              {app.data.topics.length > 0 && (
                <div class="mt-5 flex flex-wrap gap-2">
                  {app.data.topics.map((tag) => (
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 border border-blue-200">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </a>
          ))}

          {/* Planned apps (hardcoded) */}
          {hardcodedApps.map((app) => (
            <div class="bg-white dark:bg-gray-800 rounded-xl p-8 shadow-sm border border-gray-200 dark:border-gray-700">
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
                <div class="flex items-start gap-4">
                  <div class="flex-shrink-0 size-14 flex items-center justify-center rounded-xl bg-blue-100 dark:bg-blue-900/40">
                    {app.platformIcon === 'desktop' ? (
                      <Icon name="lucide:monitor" class="size-7 text-blue-500" />
                    ) : (
                      <Icon name="lucide:smartphone" class="size-7 text-blue-500" />
                    )}
                  </div>
                  <div>
                    <h2 class="text-xl font-semibold text-gray-900 dark:text-white">{app.name}</h2>
                    <span class="inline-flex items-center mt-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300">
                      {app.platform}
                    </span>
                  </div>
                </div>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-amber-50 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300 border border-amber-200 dark:border-amber-700 shrink-0">
                  {app.status}
                </span>
              </div>
              <p class="mt-4 text-gray-600 dark:text-gray-400 leading-relaxed">{app.description}</p>
              <div class="mt-5 flex flex-wrap gap-2">
                {app.tags.map((tag) => (
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 border border-blue-200">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>

        <!-- Sidebar -->
        <div class="mt-8 lg:mt-0">
          <div class="lg:sticky lg:top-24">
            <Sidebar />
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
