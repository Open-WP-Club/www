---
import { Icon } from 'astro-icon/components';
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import Contact from '../components/Contact.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import GitHubIcon from '../components/icons/GitHubIcon.astro';
import { getCollection } from 'astro:content';
import { GITHUB_ORG_URL } from '../lib/config';

const allItems = await getCollection('plugins');
const pluginCount = allItems.filter((p) => p.data.category === 'plugin').length;

const categories = [
  {
    emoji: '🌐',
    title: 'Hosting & CDN',
    description: 'Zero-cost, carbon-aware infrastructure that scales without bills.',
    tools: [
      { name: 'Cloudflare Pages', note: 'Static hosting — free tier, global edge network' },
      { name: 'Cloudflare DNS', note: 'DNS and DDoS protection — free' },
      { name: 'GitHub Pages', note: 'Fallback / secondary hosting — free' },
    ],
  },
  {
    emoji: '💻',
    title: 'Code & CI/CD',
    description: 'Everything lives in the open, built and tested automatically.',
    tools: [
      { name: 'GitHub', note: 'Source control, issues, project boards — free for open source' },
      { name: 'GitHub Actions', note: 'CI/CD pipelines, automated builds and deploys — free for public repos' },
      { name: 'Git', note: 'Version control — open source' },
    ],
  },
  {
    emoji: '🎨',
    title: 'Frontend',
    description: 'Fast, modern tooling that outputs zero JavaScript where possible.',
    tools: [
      { name: 'Astro', note: 'Static site generator — open source, ships zero JS by default' },
      { name: 'Tailwind CSS', note: 'Utility-first CSS framework — open source' },
      { name: 'TypeScript', note: 'Type safety for content collections and config' },
    ],
  },
  {
    emoji: '🔌',
    title: 'WordPress',
    description: 'The ecosystem we build for. Everything GPL, everything free.',
    tools: [
      { name: 'WordPress', note: 'CMS — GPL, powers 40%+ of the web' },
      { name: 'WooCommerce', note: 'E-commerce — GPL, the base for many of our plugins' },
      { name: 'WP-CLI', note: 'Command-line management — open source' },
      { name: 'PHPStan', note: 'Static analysis for plugin code quality' },
    ],
  },
  {
    emoji: '💬',
    title: 'Community',
    description: 'Where we coordinate, discuss, and help each other.',
    tools: [
      { name: 'Discord', note: 'Real-time chat, support, and contributor coordination — free' },
      { name: 'GitHub Discussions', note: 'Long-form conversations and RFCs — free' },
      { name: 'GitHub Issues', note: 'Bug reports and feature requests — free' },
    ],
  },
  {
    emoji: '🧪',
    title: 'Testing & Quality',
    description: 'Automated testing and code quality tools.',
    tools: [
      { name: 'Vitest', note: 'Unit testing for the website — open source' },
      { name: 'PHPUnit', note: 'Unit testing for WordPress plugins — open source' },
      { name: 'WordPress Coding Standards', note: 'PHP_CodeSniffer rules for WP conventions' },
    ],
  },
  {
    emoji: '🛠️',
    title: 'Dev Tools',
    description: 'The tools we actually use, every day.',
    tools: [
      { name: 'VS Code', note: 'Primary editor — open source' },
      { name: 'npm', note: 'Package management — free' },
      { name: 'Docker', note: 'Local WordPress development environments — open source' },
      { name: 'Playwright', note: 'End-to-end testing — open source' },
    ],
  },
];

const stats = [
  { value: '$0', label: 'Monthly infrastructure cost' },
  { value: '100%', label: 'Open-source stack' },
  { value: 'GPL + MIT', label: 'Licensing' },
];
---

<BaseLayout
  title="Tech Stack - Open WP Club"
  description="The tools and services we use to build, deploy, and maintain free WordPress software. Everything open source, everything free."
>
  <Breadcrumbs items={[{ label: 'Tech Stack' }]} />

  <!-- Hero -->
  <section class="pt-8 pb-16 bg-gradient-to-br from-blue-50 to-white dark:from-gray-900 dark:to-gray-950">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 dark:text-white leading-tight tracking-tight">
          Our <span class="text-blue-500">tech stack</span>
        </h1>
        <p class="mt-6 text-lg sm:text-xl text-gray-600 dark:text-gray-400 leading-relaxed max-w-3xl mx-auto">
          Every tool we use is either free or open source. We run the entire organization — {pluginCount}+ plugins, this website, CI/CD, community — at <strong class="text-gray-900 dark:text-white">$0 per month</strong>.
        </p>
      </div>
    </div>
  </section>

  <!-- Two-column: Content + Sidebar -->
  <section class="py-12 bg-gray-50 dark:bg-gray-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-3 lg:gap-8">

        <!-- Main content -->
        <div class="lg:col-span-2 space-y-8">

          <!-- Category cards -->
          {categories.map((cat) => (
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 sm:p-8">
              <div class="flex items-center gap-3 mb-4">
                <span class="text-2xl" aria-hidden="true">{cat.emoji}</span>
                <div>
                  <h2 class="text-xl font-bold text-gray-900 dark:text-white">{cat.title}</h2>
                  <p class="text-sm text-gray-500 dark:text-gray-500">{cat.description}</p>
                </div>
              </div>
              <ul class="space-y-3">
                {cat.tools.map((tool) => (
                  <li class="flex items-start gap-3 text-sm">
                    <Icon name="lucide:check" class="size-5 shrink-0 text-green-500 mt-0.5" />
                    <span>
                      <strong class="text-gray-900 dark:text-white">{tool.name}</strong>
                      <span class="text-gray-500 dark:text-gray-500"> — {tool.note}</span>
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          ))}

          <!-- Philosophy -->
          <div class="bg-gradient-to-br from-green-50 via-white to-green-50 dark:from-green-950/30 dark:via-gray-800 dark:to-green-950/30 rounded-xl shadow-sm border border-green-200 dark:border-green-800/50 p-6 sm:p-8">
            <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Why this matters</h2>
            <div class="space-y-4 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
              <p>
                If we can run an entire open-source organization for free, so can you. We deliberately choose tools that don't lock us (or our contributors) into paid plans, vendor lock-in, or proprietary ecosystems.
              </p>
              <p>
                This isn't about being cheap — it's about proving that good software doesn't require a budget. Every dollar we don't spend on infrastructure is a dollar we never need to extract from our users.
              </p>
            </div>
          </div>

          <!-- Stats bar -->
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            {stats.map((stat) => (
              <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 text-center">
                <p class="text-3xl font-bold text-blue-500 dark:text-blue-400">{stat.value}</p>
                <p class="mt-1 text-sm text-gray-500 dark:text-gray-500">{stat.label}</p>
              </div>
            ))}
          </div>

          <!-- CTA -->
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 sm:p-8 text-center">
            <p class="text-gray-600 dark:text-gray-400 mb-4">Want to see how it all fits together?</p>
            <a
              href={`${GITHUB_ORG_URL}/www`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-6 py-3 text-base font-medium rounded-lg text-white bg-blue-500 hover:bg-blue-600 shadow-sm transition-all duration-200"
            >
              <GitHubIcon class="size-5" />
              View this site's source code
            </a>
          </div>

        </div>

        <!-- Sidebar -->
        <div class="mt-8 lg:mt-0">
          <div class="lg:sticky lg:top-24">
            <Sidebar />
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <Contact />
</BaseLayout>
