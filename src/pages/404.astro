---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found - Open WP Club" description="The page you're looking for doesn't exist.">
  <section class="pt-32 pb-20 bg-gradient-to-br from-blue-50 to-white dark:from-gray-900 dark:to-gray-950 min-h-[70vh] flex items-center">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-7xl font-bold text-blue-600">404</p>
      <h1 class="mt-4 text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white tracking-tight">Page not found</h1>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">The page you're looking for doesn't exist or has been moved.</p>
      <form class="mt-6 max-w-sm mx-auto" action="/plugins/" method="GET">
        <div class="relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 size-5 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
          </svg>
          <input
            name="q"
            type="search"
            placeholder="Search plugins..."
            class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
            aria-label="Search plugins"
          />
        </div>
      </form>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center px-6 py-3 text-base font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 shadow-sm transition-all duration-200"
        >
          Go home
        </a>
        <a
          href="/plugins/"
          class="inline-flex items-center px-6 py-3 text-base font-medium rounded-lg text-blue-600 bg-white dark:bg-gray-900 border border-blue-600 hover:bg-blue-50 dark:hover:bg-gray-700 shadow-sm transition-all duration-200"
        >
          Browse plugins
        </a>
        <a
          href="/blog/"
          class="inline-flex items-center px-6 py-3 text-base font-medium rounded-lg text-blue-600 bg-white dark:bg-gray-900 border border-blue-600 hover:bg-blue-50 dark:hover:bg-gray-700 shadow-sm transition-all duration-200"
        >
          Read the blog
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
