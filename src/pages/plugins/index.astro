---
import { Icon } from 'astro-icon/components';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PluginCard from '../../components/PluginCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

const allItems = await getCollection('plugins');
const sorted = allItems
  .filter((p) => p.data.category === 'plugin')
  .sort((a, b) => {
    if (!a.data.lastPush || !b.data.lastPush) return 0;
    return new Date(b.data.lastPush).getTime() - new Date(a.data.lastPush).getTime();
  });

// Build category filters from topics
const categoryMap: Record<string, { label: string; icon: string; keywords: string[] }> = {
  woocommerce: {
    label: 'WooCommerce',
    icon: 'lucide:shopping-cart',
    keywords: ['woocommerce', 'woocommerce-plugin', 'wooco', 'woocoommerce', 'e-commerce', 'order-management', 'stock-management', 'pre-order', 'order-history', 'hpos', 'sku', 'inventory-management', 'inventory-management-system', 'shopify-app'],
  },
  admin: {
    label: 'Admin Tools',
    icon: 'lucide:settings',
    keywords: ['admin', 'backend', 'admin-notice', 'remover-tool', 'bulk-operation', 'bulk-editing', 'staging', 'tag-management'],
  },
  security: {
    label: 'Security',
    icon: 'lucide:shield',
    keywords: ['gdpr', 'sensitive-data', 'blocking', 'ip-blocking', 'restrict-access'],
  },
  seo: {
    label: 'SEO',
    icon: 'lucide:search',
    keywords: ['seo', 'seo-optimization', 'rank-math', 'google-scholar', 'google-scholar-scrapper'],
  },
  users: {
    label: 'Users & Roles',
    icon: 'lucide:users',
    keywords: ['users', 'user-management', 'roles-management', 'customers', 'historical-preserve'],
  },
  content: {
    label: 'Content & Forms',
    icon: 'lucide:file-text',
    keywords: ['forms', 'gravity', 'gravity-forms', 'metadata', 'search', 'searching', 'html-to-markdown', 'markdown', 'llm', 'integration', 'integrations', 'file-sharing', 'filesystem', 'manager-system', 'logo-design'],
  },
};

// Count plugins per category
const categoryCounts: Record<string, number> = {};
for (const [key, cat] of Object.entries(categoryMap)) {
  categoryCounts[key] = sorted.filter((p) =>
    p.data.topics.some((t) => cat.keywords.includes(t.toLowerCase()))
  ).length;
}

// Build a JSON-friendly version for the client script
const categoryKeywordsJson = Object.fromEntries(
  Object.entries(categoryMap).map(([key, cat]) => [key, cat.keywords])
);

// Badge logic
const now = new Date();
const thirtyDaysAgo = new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000);
const starThreshold = sorted.length > 0
  ? [...sorted].sort((a, b) => b.data.stars - a.data.stars)[Math.min(4, sorted.length - 1)]?.data.stars ?? 0
  : 0;
---

<BaseLayout title="All Plugins - Open WP Club" description={`${sorted.length} free, open-source WordPress plugins. Browse the full catalog, sorted by most recently updated.`}>
  <Breadcrumbs items={[{ label: 'Plugins' }]} />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-10">

    <!-- Page header -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white tracking-tight">Plugins</h1>
      <p class="mt-1 text-gray-500 dark:text-gray-400">{sorted.length} free, open-source WordPress plugins</p>
    </div>

    <div class="flex gap-8 items-start">

      <!-- Left sidebar -->
      <aside class="hidden lg:block w-56 shrink-0 sticky top-6">

        <!-- Search -->
        <div class="relative mb-6">
          <Icon name="lucide:search" class="absolute left-3 top-1/2 -translate-y-1/2 size-4 text-gray-400 pointer-events-none" />
          <input
            id="plugin-search"
            type="search"
            placeholder="Search plugins..."
            class="w-full pl-9 pr-3 py-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-sm text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
            aria-label="Search plugins"
          />
        </div>

        <!-- Sort -->
        <div class="mb-6">
          <p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider mb-2">Sort by</p>
          <select
            id="plugin-sort"
            class="w-full px-3 py-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-sm text-gray-700 dark:text-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
            aria-label="Sort plugins"
          >
            <option value="updated">Recently updated</option>
            <option value="stars">Most stars</option>
            <option value="name">Name A-Z</option>
          </select>
        </div>

        <!-- Categories -->
        <div>
          <p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider mb-2">Category</p>
          <nav class="space-y-0.5" id="category-filters">
            <button
              data-category="all"
              class="category-btn w-full flex items-center justify-between px-3 py-2 rounded-lg text-sm font-medium transition-colors duration-150 bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400"
            >
              <span class="flex items-center gap-2">
                <Icon name="lucide:layout-grid" class="size-4 shrink-0" />
                All plugins
              </span>
              <span class="text-xs text-gray-400 dark:text-gray-500">{sorted.length}</span>
            </button>
            {Object.entries(categoryMap).map(([key, cat]) => (
              categoryCounts[key] > 0 && (
                <button
                  data-category={key}
                  class="category-btn w-full flex items-center justify-between px-3 py-2 rounded-lg text-sm font-medium transition-colors duration-150 text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white"
                >
                  <span class="flex items-center gap-2">
                    <Icon name={cat.icon} class="size-4 shrink-0" />
                    {cat.label}
                  </span>
                  <span class="text-xs text-gray-400 dark:text-gray-500">{categoryCounts[key]}</span>
                </button>
              )
            ))}
          </nav>
        </div>

        <!-- RSS -->
        <div class="mt-6 pt-6 border-t border-gray-100 dark:border-gray-800">
          <a
            href="/plugins-rss.xml"
            class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-orange-500 dark:hover:text-orange-400 transition-colors"
            target="_blank"
            rel="noopener noreferrer"
          >
            <Icon name="lucide:rss" class="size-4 shrink-0" />
            Plugin Updates RSS
          </a>
        </div>

      </aside>

      <!-- Main content -->
      <div class="flex-1 min-w-0">

        <!-- Mobile controls -->
        <div class="lg:hidden mb-4 flex gap-2">
          <div class="relative flex-1">
            <Icon name="lucide:search" class="absolute left-3 top-1/2 -translate-y-1/2 size-4 text-gray-400 pointer-events-none" />
            <input
              id="plugin-search-mobile"
              type="search"
              placeholder="Search plugins..."
              class="w-full pl-9 pr-3 py-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-sm text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-colors"
              aria-label="Search plugins"
            />
          </div>
          <select
            id="plugin-sort-mobile"
            class="px-3 py-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-sm text-gray-700 dark:text-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-colors"
          >
            <option value="updated">Recent</option>
            <option value="stars">Stars</option>
            <option value="name">A-Z</option>
          </select>
        </div>

        <!-- Mobile category pills -->
        <div class="lg:hidden flex flex-wrap gap-2 mb-4" id="category-filters-mobile">
          <button data-category="all" class="category-btn-mobile inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-xs font-medium border transition-colors bg-blue-500 text-white border-blue-500">
            All <span class="opacity-75">{sorted.length}</span>
          </button>
          {Object.entries(categoryMap).map(([key, cat]) => (
            categoryCounts[key] > 0 && (
              <button
                data-category={key}
                class="category-btn-mobile inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-xs font-medium border transition-colors bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border-gray-200 dark:border-gray-700"
              >
                {cat.label} <span class="opacity-60">{categoryCounts[key]}</span>
              </button>
            )
          ))}
        </div>

        <div id="plugin-grid" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
          {sorted.map((plugin) => (
            <div
              class="plugin-item"
              data-name={plugin.data.name.toLowerCase()}
              data-description={plugin.data.description.toLowerCase()}
              data-stars={plugin.data.stars}
              data-updated={plugin.data.lastPush}
              data-topics={plugin.data.topics.join(' ').toLowerCase()}
            >
              <PluginCard
                slug={plugin.id}
                name={plugin.data.name}
                description={plugin.data.description}
                version={plugin.data.version}
                stars={plugin.data.stars}
                lastPush={plugin.data.lastPush}
                downloads={plugin.data.downloads}
                language={plugin.data.language}
                isNew={new Date(plugin.data.lastPush) > thirtyDaysAgo}
                isPopular={plugin.data.stars >= starThreshold && starThreshold > 0}
              />
            </div>
          ))}
        </div>
        <p id="no-results" class="hidden text-center text-gray-500 dark:text-gray-500 py-12">No plugins match your search or filter.</p>

        <div class="mt-6">
          <p id="plugin-count" class="text-sm text-gray-400 dark:text-gray-500"></p>
        </div>
        <!-- Sentinel for infinite scroll -->
        <div id="load-more-sentinel" class="h-4 mt-4"></div>
      </div>

    </div>
  </div>
</BaseLayout>

<script define:vars={{ categoryKeywordsJson }}>
  window.__categoryKeywords = categoryKeywordsJson;
</script>

<script>
  import { debounce } from '../../lib/debounce';

  document.addEventListener('astro:page-load', () => {
    const search = document.getElementById('plugin-search') as HTMLInputElement | null;
    const searchMobile = document.getElementById('plugin-search-mobile') as HTMLInputElement | null;
    const sort = document.getElementById('plugin-sort') as HTMLSelectElement | null;
    const sortMobile = document.getElementById('plugin-sort-mobile') as HTMLSelectElement | null;
    const grid = document.getElementById('plugin-grid');
    const countEl = document.getElementById('plugin-count');
    const noResults = document.getElementById('no-results');
    const sentinel = document.getElementById('load-more-sentinel');
    const filterBtns = document.querySelectorAll('.category-btn') as NodeListOf<HTMLButtonElement>;
    const filterBtnsMobile = document.querySelectorAll('.category-btn-mobile') as NodeListOf<HTMLButtonElement>;
    if (!grid || !countEl || !noResults) return;

    const items = [...grid.querySelectorAll('.plugin-item')] as HTMLElement[];
    const categoryKeywords = (window as any).__categoryKeywords as Record<string, string[]>;
    const PAGE_SIZE = 15;

    let activeCategory = 'all';
    let visibleCount = PAGE_SIZE;
    let currentMatched: HTMLElement[] = [];

    function getSearch() { return (search?.value || searchMobile?.value || '').toLowerCase().trim(); }
    function getSort() { return sort?.value || sortMobile?.value || 'updated'; }

    function matchesCategory(topics: string): boolean {
      if (activeCategory === 'all') return true;
      const keywords = categoryKeywords[activeCategory] || [];
      return keywords.some((kw) => topics.includes(kw));
    }

    function updateFilterButtons() {
      [...filterBtns, ...filterBtnsMobile].forEach((btn) => {
        const cat = btn.dataset.category;
        const isActive = cat === activeCategory;
        if (btn.classList.contains('category-btn')) {
          btn.className = `category-btn w-full flex items-center justify-between px-3 py-2 rounded-lg text-sm font-medium transition-colors duration-150 ${
            isActive
              ? 'bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400'
              : 'text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white'
          }`;
        } else {
          btn.className = `category-btn-mobile inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-xs font-medium border transition-colors ${
            isActive
              ? 'bg-blue-500 text-white border-blue-500'
              : 'bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border-gray-200 dark:border-gray-700'
          }`;
        }
      });
    }

    function syncControls(source: 'desktop' | 'mobile') {
      if (source === 'desktop') {
        if (searchMobile && search) searchMobile.value = search.value;
        if (sortMobile && sort) sortMobile.value = sort.value;
      } else {
        if (search && searchMobile) search.value = searchMobile.value;
        if (sort && sortMobile) sort.value = sortMobile.value;
      }
    }

    function showItems() {
      const toShow = currentMatched.slice(0, visibleCount);
      items.forEach((item) => { item.style.display = 'none'; });
      toShow.forEach((el) => { el.style.display = ''; grid!.appendChild(el); });

      const label = activeCategory === 'all' ? '' : ' in this category';
      const showing = Math.min(visibleCount, currentMatched.length);
      countEl!.textContent = currentMatched.length > showing
        ? `Showing ${showing} of ${currentMatched.length} plugins${label}`
        : `${currentMatched.length} plugin${currentMatched.length !== 1 ? 's' : ''}${label}`;
      noResults!.classList.toggle('hidden', currentMatched.length > 0);

      if (sentinel) sentinel.style.display = visibleCount >= currentMatched.length ? 'none' : '';
    }

    function update(resetVisible = true) {
      if (resetVisible) visibleCount = PAGE_SIZE;
      const query = getSearch();
      const sortBy = getSort();

      currentMatched = items.filter((item) => {
        const name = item.dataset.name || '';
        const desc = item.dataset.description || '';
        const topics = item.dataset.topics || '';
        return (!query || name.includes(query) || desc.includes(query) || topics.includes(query))
          && matchesCategory(topics);
      }).sort((a, b) => {
        if (sortBy === 'stars') return Number(b.dataset.stars) - Number(a.dataset.stars);
        if (sortBy === 'name') return (a.dataset.name || '').localeCompare(b.dataset.name || '');
        return (b.dataset.updated || '').localeCompare(a.dataset.updated || '');
      });

      showItems();

      const urlParams = new URLSearchParams();
      const q = getSearch();
      const s = getSort();
      if (q) urlParams.set('q', q);
      if (s && s !== 'updated') urlParams.set('sort', s);
      if (activeCategory !== 'all') urlParams.set('cat', activeCategory);
      const newUrl = urlParams.toString() ? `${window.location.pathname}?${urlParams}` : window.location.pathname;
      history.replaceState(null, '', newUrl);
    }

    // Infinite scroll via IntersectionObserver
    if (sentinel) {
      const observer = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting && visibleCount < currentMatched.length) {
          visibleCount += PAGE_SIZE;
          showItems();
        }
      }, { rootMargin: '200px' });
      observer.observe(sentinel);
    }

    [...filterBtns, ...filterBtnsMobile].forEach((btn) => {
      btn.addEventListener('click', () => {
        activeCategory = btn.dataset.category || 'all';
        updateFilterButtons();
        update();
      });
    });

    search?.addEventListener('input', debounce(() => { syncControls('desktop'); update(); }, 150));
    searchMobile?.addEventListener('input', debounce(() => { syncControls('mobile'); update(); }, 150));
    sort?.addEventListener('change', () => { syncControls('desktop'); update(); });
    sortMobile?.addEventListener('change', () => { syncControls('mobile'); update(); });

    // Restore URL state
    const params = new URLSearchParams(window.location.search);
    const initialQuery = params.get('q') || '';
    const initialSort = params.get('sort') || 'updated';
    const validCategories = new Set(['all', ...Object.keys(categoryKeywords)]);
    const rawCat = params.get('cat') || 'all';
    const initialCat = validCategories.has(rawCat) ? rawCat : 'all';
    if (search) search.value = initialQuery;
    if (searchMobile) searchMobile.value = initialQuery;
    if (sort) sort.value = initialSort;
    if (sortMobile) sortMobile.value = initialSort;
    activeCategory = initialCat;
    updateFilterButtons();

    update(false);
  });
</script>
