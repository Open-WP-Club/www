---
import { Icon } from 'astro-icon/components';
import GitHubIcon from '../../components/icons/GitHubIcon.astro';
import PluginCard from '../../components/PluginCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';
import { GITHUB_ORG_URL, DISCORD_URL } from '../../lib/config';
import { readFileSync, existsSync } from 'node:fs';

export async function getStaticPaths() {
  const allItems = await getCollection('plugins');
  const plugins = allItems.filter((p) => p.data.category === 'plugin');
  return plugins.map((plugin) => ({
    params: { slug: plugin.id },
    props: { plugin, allPlugins: plugins },
  }));
}

const { plugin, allPlugins } = Astro.props;
const { name, description, version, githubUrl, wordpressUrl, stars, forks, openIssues, lastPush, license, language, defaultBranch, downloads } = plugin.data;

const downloadsNum = downloads ? parseInt(downloads, 10) : 0;

const readmePath = `src/data/readmes/${plugin.id}.html`;
let safeReadmeHtml = `<p>No README available. Visit the <a href="${githubUrl}">GitHub repository</a> for more information.</p>`;
if (existsSync(readmePath)) {
  try {
    safeReadmeHtml = readFileSync(readmePath, 'utf-8');
  } catch (e) {
    console.warn(`[plugins/${plugin.id}] Failed to read README: ${(e as Error).message}`);
  }
}
const downloadUrl = `${githubUrl}/archive/refs/heads/${defaultBranch}.zip`;
const wpCliCommand = `wp plugin install ${downloadUrl} --activate`;
const playgroundBlueprint = JSON.stringify({ steps: [{ step: 'installPlugin', pluginZipFile: { resource: 'url', url: downloadUrl }, options: { activate: true } }] });
const playgroundUrl = `https://playground.wordpress.net/#${playgroundBlueprint}`;

// Load per-repo contributors
interface RepoContributor { login: string; avatar: string; profileUrl: string; contributions: number; }
const repoContribPath = 'src/data/repo-contributors.json';
let pluginContributors: RepoContributor[] = [];
if (existsSync(repoContribPath)) {
  const allRepoContribs = JSON.parse(readFileSync(repoContribPath, 'utf-8'));
  pluginContributors = (allRepoContribs[plugin.id] || []).slice(0, 10);
}

// Related plugins: find plugins with overlapping topics
const currentTopics = new Set(plugin.data.topics.map((t: string) => t.toLowerCase()));
const related = allPlugins
  .filter((p) => p.id !== plugin.id)
  .map((p) => {
    const overlap = p.data.topics.filter((t: string) => currentTopics.has(t.toLowerCase())).length;
    return { plugin: p, overlap };
  })
  .filter((r) => r.overlap > 0)
  .sort((a, b) => b.overlap - a.overlap || b.plugin.data.stars - a.plugin.data.stars)
  .slice(0, 3)
  .map((r) => r.plugin);

// Parse headings from README HTML for Table of Contents
const headingRegex = /<h([23])[^>]*(?:id="([^"]*)")?[^>]*>(.*?)<\/h[23]>/gi;
const toc: Array<{ level: number; id: string; text: string }> = [];
let match;
while ((match = headingRegex.exec(safeReadmeHtml)) !== null) {
  const level = parseInt(match[1]);
  const text = match[3].replace(/<[^>]*>/g, '').trim();
  const id = match[2] || text.toLowerCase().replace(/[^\w\s-]/g, '').replace(/\s+/g, '-');
  toc.push({ level, id, text });
}

// Add IDs to headings so ToC links work
let tocIndex = 0;
const processedHtml = safeReadmeHtml.replace(/<h([23])([^>]*)>/gi, (_match, level, attrs) => {
  if (tocIndex < toc.length) {
    const id = toc[tocIndex].id;
    tocIndex++;
    if (attrs.includes('id=')) return _match;
    return `<h${level}${attrs} id="${id}">`;
  }
  return _match;
});

function formatDate(dateStr: string): string {
  if (!dateStr) return 'N/A';
  return new Date(dateStr).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

const categoryMap: Record<string, string> = {
  plugin: 'WordPress Plugin',
  app: 'Application',
  website: 'WebApplication',
  tool: 'DeveloperApplication',
};

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name,
  description,
  applicationCategory: categoryMap[plugin.data.category] || 'WordPress Plugin',
  operatingSystem: 'Any',
  ...(version && version !== 'N/A' && { softwareVersion: version }),
  ...(license && { license: `https://spdx.org/licenses/${license}` }),
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  codeRepository: githubUrl,
};
---

<BaseLayout title={`${name} - Open WP Club`} description={description} ogType="article" ogImage={new URL(`/og/plugin/${plugin.id}.png`, Astro.site).toString()} jsonLd={softwareSchema}>
  <Breadcrumbs items={[{ label: 'Plugins', href: '/plugins/' }, { label: name }]} />

  <!-- Header -->
  <section class="bg-white dark:bg-gray-900 pb-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8">
      <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6">
        <div class="flex-1">
          <div class="flex items-center gap-3 flex-wrap">
            <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white">{name}</h1>
            {version && version !== 'N/A' && (
              <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 dark:bg-blue-900/40 text-blue-800 dark:text-blue-300">
                v{version}
              </span>
            )}
          </div>
          <p class="mt-3 text-lg text-gray-600 dark:text-gray-400 leading-relaxed max-w-3xl">{description}</p>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a
            href={downloadUrl}
            class="inline-flex items-center px-5 py-2.5 border border-transparent text-sm font-medium rounded-lg text-white bg-blue-500 hover:bg-blue-600 transition-colors duration-200"
          >
            <Icon name="lucide:download" class="size-4 mr-2" />
            Download ZIP
          </a>
          <a
            href={githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-5 py-2.5 border border-gray-900 text-sm font-medium rounded-lg text-white bg-gray-900 hover:bg-gray-800 transition-colors duration-200"
          >
            <GitHubIcon class="size-4 mr-2" />
            GitHub
          </a>
          <a
            href={playgroundUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-5 py-2.5 border border-blue-300 dark:border-blue-700 text-sm font-medium rounded-lg text-blue-700 dark:text-blue-300 bg-blue-50 dark:bg-blue-900/20 hover:bg-blue-100 dark:hover:bg-blue-900/40 transition-colors duration-200"
          >
            <Icon name="lucide:play" class="size-4 mr-2" />
            Try in Playground
          </a>
          <a
            href={`${githubUrl}/issues/new`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-5 py-2.5 border border-gray-300 dark:border-gray-600 text-sm font-medium rounded-lg text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors duration-200"
          >
            <Icon name="lucide:circle-alert" class="size-4 mr-2" />
            Report Issue
          </a>
          {wordpressUrl && (
            <a
              href={wordpressUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center px-5 py-2.5 border border-blue-500 text-sm font-medium rounded-lg text-blue-500 bg-white dark:bg-gray-900 hover:bg-blue-50 dark:hover:bg-gray-700 transition-colors duration-200"
            >
              WordPress.org
            </a>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Two-column: README + Sidebar -->
  <section class="py-12 bg-gray-50 dark:bg-gray-950" transition:name="plugin-content">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-3 lg:gap-8">

        <!-- README -->
        <div class="lg:col-span-2">
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 sm:p-8 lg:p-10">
            <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-6 pb-4 border-b border-gray-200 dark:border-gray-700">README</h2>
            <div class="prose dark:prose-invert max-w-none" set:html={processedHtml} />
          </div>
        </div>

        <!-- Sidebar -->
        <div class="mt-8 lg:mt-0 space-y-6">

          {toc.length > 2 && (
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
              <h3 class="text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-3">On this page</h3>
              <nav class="space-y-1">
                {toc.map((item) => (
                  <a
                    href={`#${item.id}`}
                    class={`block text-sm text-gray-600 dark:text-gray-400 hover:text-blue-500 dark:hover:text-blue-400 transition-colors truncate ${item.level === 3 ? 'pl-3' : ''}`}
                  >
                    {item.text}
                  </a>
                ))}
              </nav>
            </div>
          )}

          <!-- Plugin Details -->
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
            <h3 class="text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-4">Details</h3>
            <dl class="space-y-3 text-sm">
              {version && version !== 'N/A' && (
                <div class="flex justify-between">
                  <dt class="text-gray-500 dark:text-gray-400">Version</dt>
                  <dd class="text-gray-900 dark:text-white font-medium">{version}</dd>
                </div>
              )}
              {downloadsNum > 0 && (
                <div class="flex justify-between">
                  <dt class="text-gray-500 dark:text-gray-400">Downloads</dt>
                  <dd class="text-gray-900 dark:text-white font-medium">{downloadsNum.toLocaleString()}</dd>
                </div>
              )}
              {lastPush && (
                <div class="flex justify-between">
                  <dt class="text-gray-500 dark:text-gray-400">Last updated</dt>
                  <dd class="text-gray-900 dark:text-white font-medium">{formatDate(lastPush)}</dd>
                </div>
              )}
              {license && (
                <div class="flex justify-between">
                  <dt class="text-gray-500 dark:text-gray-400">License</dt>
                  <dd class="text-gray-900 dark:text-white font-medium">{license}</dd>
                </div>
              )}
              {language && (
                <div class="flex justify-between">
                  <dt class="text-gray-500 dark:text-gray-400">Language</dt>
                  <dd class="inline-flex items-center gap-1.5 text-gray-900 dark:text-white font-medium">
                    <span class="size-2.5 rounded-full bg-blue-500"></span>
                    {language}
                  </dd>
                </div>
              )}
              <div class="flex justify-between">
                <dt class="text-gray-500 dark:text-gray-400">Stars</dt>
                <dd class="text-gray-900 dark:text-white font-medium">{stars}</dd>
              </div>
              {openIssues > 0 && (
                <div class="flex justify-between">
                  <dt class="text-gray-500 dark:text-gray-400">Open issues</dt>
                  <dd class="text-gray-900 dark:text-white font-medium">{openIssues}</dd>
                </div>
              )}
            </dl>
          </div>

          <!-- Download card -->
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
            <h3 class="text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-3">Download</h3>
            <a
              href={downloadUrl}
              class="flex items-center justify-center gap-2 w-full px-4 py-3 text-sm font-medium rounded-lg text-white bg-blue-500 hover:bg-blue-600 transition-colors duration-200"
            >
              <Icon name="lucide:download" class="size-4" />
              Download ZIP
            </a>
            {wordpressUrl && (
              <a
                href={wordpressUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center gap-2 w-full mt-3 px-4 py-3 text-sm font-medium rounded-lg text-blue-500 bg-white dark:bg-gray-800 border border-blue-200 dark:border-blue-700 hover:bg-blue-50 dark:hover:bg-gray-700 transition-colors duration-200"
              >
                Get from WordPress.org
              </a>
            )}
            <a
              href={playgroundUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 w-full mt-3 px-4 py-3 text-sm font-medium rounded-lg text-blue-700 dark:text-blue-300 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-700 hover:bg-blue-100 dark:hover:bg-blue-900/40 transition-colors duration-200"
            >
              <Icon name="lucide:play" class="size-4" />
              Try in Playground
            </a>
          </div>

          <!-- WP-CLI Install -->
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
            <h3 class="text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-3">WP-CLI</h3>
            <div class="relative group">
              <pre class="bg-gray-900 text-gray-100 text-xs rounded-lg p-3 pr-10 overflow-x-auto"><code id="wpcli-command">{wpCliCommand}</code></pre>
              <button
                id="copy-wpcli"
                class="absolute top-2 right-2 p-1.5 rounded-md bg-gray-700 hover:bg-gray-600 text-gray-300 hover:text-white transition-colors"
                title="Copy to clipboard"
                aria-label="Copy WP-CLI command"
              >
                <Icon name="lucide:copy" class="size-4" id="copy-icon" />
                <Icon name="lucide:check" class="size-4 hidden" id="copied-icon" />
              </button>
            </div>
          </div>

          {pluginContributors.length > 0 && (
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
              <h3 class="text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-3">Contributors</h3>
              <div class="flex flex-wrap gap-2">
                {pluginContributors.map((c) => (
                  <a
                    href={c.profileUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    title={`${c.login} (${c.contributions} commits)`}
                    class="group relative"
                  >
                    <img
                      src={`${c.avatar}&s=64`}
                      alt={c.login}
                      width="32"
                      height="32"
                      loading="lazy"
                      class="size-8 rounded-full ring-2 ring-white dark:ring-gray-800 group-hover:ring-blue-500 transition-all"
                    />
                  </a>
                ))}
              </div>
              <p class="mt-2 text-xs text-gray-500 dark:text-gray-400">{pluginContributors.length} contributor{pluginContributors.length !== 1 ? 's' : ''}</p>
            </div>
          )}

          <!-- Shared sidebar -->
          <Sidebar />

        </div>
      </div>
    </div>
  </section>

  {related.length > 0 && (
    <section class="py-12 bg-white dark:bg-gray-900">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Related Plugins</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {related.map((rel) => (
            <PluginCard
              slug={rel.id}
              name={rel.data.name}
              description={rel.data.description}
              version={rel.data.version}
              stars={rel.data.stars}
              lastPush={rel.data.lastPush}
              downloads={rel.data.downloads}
              language={rel.data.language}
            />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('copy-wpcli');
    const command = document.getElementById('wpcli-command');
    const copyIcon = document.getElementById('copy-icon');
    const copiedIcon = document.getElementById('copied-icon');
    if (!btn || !command || !copyIcon || !copiedIcon) return;

    btn.addEventListener('click', async () => {
      await navigator.clipboard.writeText(command.textContent || '');
      copyIcon.classList.add('hidden');
      copiedIcon.classList.remove('hidden');
      setTimeout(() => {
        copyIcon.classList.remove('hidden');
        copiedIcon.classList.add('hidden');
      }, 2000);
    });
  });
</script>
